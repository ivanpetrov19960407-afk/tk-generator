{
  "appId": "com.tk.generator.desktop",
  "productName": "TK Generator",
  "electronVersion": "35.7.5",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "desktop/**/*",
    "src/**/*",
    "public/**/*",
    "assets/**/*",
    "data/**/*",
    "templates/**/*",
    "config/**/*",
    "schemas/**/*",
    "plugins/**/*",
    "vendor/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "desktop/main.js"
  },
  "win": {
    "target": [
      "nsis"
    ]
  },
  "mac": {
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ]
  },
  "publish": [
    {
      "provider": "github",
      "owner": "ivanpetrov19960407-afk",
      "repo": "tk-generator"
    }
  ]
}
